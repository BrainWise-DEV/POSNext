{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Capabilities granted to the main webview",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"core:window:default",
		"core:webview:default",
		"core:app:default",
		"core:event:default",
		"core:menu:default",
		"core:resources:default",
		"core:tray:default",
		"shell:allow-open",
		"dialog:default",
		"process:default",
		"updater:default",
		"store:default",
		"stronghold:default",
		{
			"identifier": "http:default",
			"allow": [
				{ "url": "https://*.frappe.cloud/*" },
				{ "url": "https://*.erpnext.com/*" }
			]
		}
	]
}
