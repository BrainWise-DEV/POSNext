{
 "absolute_value": 0,
 "align_labels_right": 0,
 "custom_format": 1,
 "default_print_language": "en",
 "disabled": 0,
 "doc_type": "POS Closing Shift",
 "docstatus": 0,
 "doctype": "Print Format",
 "font_size": 11,
 "html": "<style>\n/* =========================================\n   THERMAL PRINT \u2014 MODERN EOD STYLE\n   ========================================= */\n\n@page {\n    size: 80mm auto;\n    margin: 0;\n}\n\nbody {\n    font-family: Arial, sans-serif;\n    width: 74mm;\n    margin: 0 auto;\n    padding: 6px;\n    padding-bottom: 40px;\n    background: #fff;\n    color: #000;\n    font-size: 11px;\n    line-height: 1.45;\n    -webkit-print-color-adjust: exact;\n    print-color-adjust: exact;\n}\n\n/* =========================================\n   RECEIPT CONTAINER\n   ========================================= */\n\n.receipt {\n    direction: ltr;\n    width: 100%;\n}\n\n/* =========================================\n   MAIN HEADER\n   ========================================= */\n\n.eod-main-title {\n    text-align: center;\n    font-size: 18px;\n    font-weight: 900;\n    letter-spacing: 1px;\n    padding: 10px 0 8px;\n    border-bottom: 2px solid #000;\n    margin-bottom: 10px;\n    text-transform: uppercase;\n}\n\n.eod-company {\n    text-align: center;\n    margin-bottom: 12px;\n}\n\n.eod-company-name {\n    font-size: 15px;\n    font-weight: 900;\n    margin-bottom: 3px;\n}\n\n.eod-company-address {\n    font-size: 10px;\n    color: #111;\n}\n\n/* =========================================\n   SECTION TITLES\n   ========================================= */\n\n.eod-section-title {\n    background: #e5e5e5;\n    border-top: 1px solid #000;\n    border-bottom: 1px solid #000;\n    padding: 5px 8px;\n    margin: 12px 0 8px;\n    font-size: 11px;\n    font-weight: 900;\n    text-transform: uppercase;\n    letter-spacing: .5px;\n}\n\n/* =========================================\n   ROWS\n   ========================================= */\n\n.eod-row {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    gap: 10px;\n    padding: 5px 2px;\n    font-size: 11px;\n}\n\n.eod-row:not(:last-child) {\n    border-bottom: 1px dashed #d9d9d9;\n}\n\n.eod-label {\n    flex: 1;\n    color: #111;\n}\n\n.eod-value {\n    font-weight: 700;\n    text-align: right;\n    white-space: nowrap;\n    font-variant-numeric: tabular-nums;\n}\n\n/* =========================================\n   GRAND TOTALS\n   ========================================= */\n\n.eod-row.grand {\n    background: #e9e9e9;\n    color: #000;\n    padding: 8px 6px;\n    margin-top: 6px;\n    border: 1px solid #bdbdbd;\n    border-bottom: none !important;\n    font-size: 13px;\n    font-weight: 900;\n}\n\n.eod-row.grand .eod-label,\n.eod-row.grand .eod-value {\n    color: #000;\n}\n\n/* =========================================\n   ITEMS\n   ========================================= */\n\n.eod-item {\n    padding: 7px 0;\n    border-bottom: 1px dashed #bdbdbd;\n}\n\n.eod-item:last-child {\n    border-bottom: none;\n}\n\n.eod-item-name {\n    font-size: 11px;\n    font-weight: 800;\n    margin-bottom: 3px;\n    word-break: break-word;\n}\n\n.eod-item-meta {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    gap: 8px;\n    font-size: 10px;\n}\n\n.eod-item-left {\n    color: #111;\n}\n\n.eod-item-right {\n    font-weight: 800;\n    white-space: nowrap;\n}\n\n/* =========================================\n   PAYMENT BLOCKS\n   ========================================= */\n\n.eod-payment {\n    border: 1px solid #000;\n    padding: 7px;\n    margin-bottom: 8px;\n}\n\n.eod-payment-title {\n    font-size: 11px;\n    font-weight: 900;\n    text-transform: uppercase;\n    margin-bottom: 6px;\n    padding-bottom: 4px;\n    border-bottom: 1px dashed #999;\n}\n\n/* =========================================\n   TAGS\n   ========================================= */\n\n.eod-tag {\n    display: inline-block;\n    padding: 1px 5px;\n    margin-left: 4px;\n    font-size: 9px;\n    font-weight: 900;\n    border: 1px solid #000;\n}\n\n.eod-tag.short {\n    background: #d9d9d9;\n    color: #000;\n    border: 1px solid #000;\n}\n\n.eod-tag.over {\n    background: #efefef;\n    color: #000;\n    border: 1px solid #000;\n}\n\n/* =========================================\n   FOOTER\n   ========================================= */\n\n.eod-footer {\n    text-align: center;\n    margin-top: 14px;\n    padding-top: 8px;\n    border-top: 1px dashed #000;\n    font-size: 10px;\n    line-height: 1.5;\n}\n\n.eod-end {\n    margin-top: 4px;\n    font-weight: 900;\n    letter-spacing: 1px;\n}\n</style>\n\n{%- set company_doc = frappe.get_cached_doc(\"Company\", doc.company) -%}\n{%- set profile_doc = frappe.get_cached_doc(\"POS Profile\", doc.pos_profile) -%}\n{%- set user_doc = frappe.get_cached_doc(\"User\", doc.user) -%}\n\n{%- set items = get_items_sold(doc) -%}\n\n{% set total_expected = namespace(v=0.0) %}\n{% set total_counted = namespace(v=0.0) %}\n\n{% for p in doc.payment_reconciliation %}\n    {% set total_expected.v = total_expected.v + (p.expected_amount or 0) %}\n    {% set total_counted.v = total_counted.v + (p.closing_amount or 0) %}\n{% endfor %}\n\n{% set short_over = total_counted.v - total_expected.v %}\n\n<div class=\"receipt\">\n\n    <!-- =========================================\n         HEADER\n    ========================================== -->\n\n    <div class=\"eod-main-title\">\n        End of Day Report\n    </div>\n\n    <div class=\"eod-company\">\n        <div class=\"eod-company-name\">\n            {{ company_doc.company_name }}\n        </div>\n\n        {% if profile_doc.company_address %}\n        <div class=\"eod-company-address\">\n            {{ profile_doc.company_address }}\n        </div>\n        {% endif %}\n    </div>\n\n    <!-- =========================================\n         INFO\n    ========================================== -->\n\n    <div class=\"eod-section-title\">\n        Session Information\n    </div>\n\n    <div class=\"eod-row\">\n        <span class=\"eod-label\">POS Profile</span>\n        <span class=\"eod-value\">{{ doc.pos_profile }}</span>\n    </div>\n\n    <div class=\"eod-row\">\n        <span class=\"eod-label\">Cashier</span>\n        <span class=\"eod-value\">\n            {{ user_doc.full_name or doc.user }}\n        </span>\n    </div>\n\n    <div class=\"eod-row\">\n        <span class=\"eod-label\">Opened</span>\n        <span class=\"eod-value\">\n            {{ frappe.utils.format_datetime(doc.period_start_date) }}\n        </span>\n    </div>\n\n    <div class=\"eod-row\">\n        <span class=\"eod-label\">Closed</span>\n        <span class=\"eod-value\">\n            {{ frappe.utils.format_datetime(doc.period_end_date) }}\n        </span>\n    </div>\n\n    <div class=\"eod-row\">\n        <span class=\"eod-label\">Closing ID</span>\n        <span class=\"eod-value\">{{ doc.name }}</span>\n    </div>\n\n    <!-- =========================================\n         SALES TOTALS\n    ========================================== -->\n\n    <div class=\"eod-section-title\">\n        Sales Totals\n    </div>\n\n    <div class=\"eod-row\">\n        <span class=\"eod-label\">Invoices</span>\n        <span class=\"eod-value\">\n            {{ doc.pos_transactions|length }}\n        </span>\n    </div>\n\n    <div class=\"eod-row\">\n        <span class=\"eod-label\">Items Sold</span>\n        <span class=\"eod-value\">\n            {{ \"{:.2f}\".format(doc.total_quantity or 0) }}\n        </span>\n    </div>\n\n    <div class=\"eod-row\">\n        <span class=\"eod-label\">Net Total</span>\n        <span class=\"eod-value\">\n            {{ \"{:,.2f}\".format(doc.net_total or 0) }}\n        </span>\n    </div>\n\n    {% set tax_total = doc.taxes|sum(attribute='amount') if doc.taxes else 0 %}\n\n    <div class=\"eod-row\">\n        <span class=\"eod-label\">Tax Total</span>\n        <span class=\"eod-value\">\n            {{ \"{:,.2f}\".format(tax_total) }}\n        </span>\n    </div>\n\n    <div class=\"eod-row grand\">\n        <span class=\"eod-label\">Grand Total</span>\n        <span class=\"eod-value\">\n            {{ \"{:,.2f}\".format(doc.grand_total or 0) }}\n        </span>\n    </div>\n\n    <!-- =========================================\n         ITEMS SOLD\n    ========================================== -->\n\n    {% if items %}\n\n    <div class=\"eod-section-title\">\n        Items Sold\n    </div>\n\n    {% for it in items %}\n\n    <div class=\"eod-item\">\n\n        <div class=\"eod-item-name\">\n            {{ it.item_name or it.item_code }}\n        </div>\n\n        <div class=\"eod-item-meta\">\n\n            <div class=\"eod-item-left\">\n                Qty {{ \"{:g}\".format(it.qty | float) }}\n                \u00d7\n                {{ \"{:,.2f}\".format((it.amount / it.qty) if it.qty else 0) }}\n            </div>\n\n            <div class=\"eod-item-right\">\n                {{ \"{:,.2f}\".format(it.amount | float) }}\n            </div>\n\n        </div>\n\n    </div>\n\n    {% endfor %}\n\n    {% endif %}\n\n    <!-- =========================================\n         TAXES\n    ========================================== -->\n\n    {% if doc.taxes %}\n\n    <div class=\"eod-section-title\">\n        Taxes\n    </div>\n\n    {% for t in doc.taxes %}\n\n    <div class=\"eod-row\">\n\n        <span class=\"eod-label\">\n            {{ t.account_head }}\n            {% if t.rate %}\n                ({{ \"{:g}\".format(t.rate | float) }}%)\n            {% endif %}\n        </span>\n\n        <span class=\"eod-value\">\n            {{ \"{:,.2f}\".format(t.amount or 0) }}\n        </span>\n\n    </div>\n\n    {% endfor %}\n\n    {% endif %}\n\n    <!-- =========================================\n         PAYMENTS\n    ========================================== -->\n\n    <div class=\"eod-section-title\">\n        Payments\n    </div>\n\n    {% for p in doc.payment_reconciliation %}\n\n    {% set diff = (p.closing_amount or 0) - (p.expected_amount or 0) %}\n\n    <div class=\"eod-payment\">\n\n        <div class=\"eod-payment-title\">\n            {{ p.mode_of_payment }}\n        </div>\n\n        <div class=\"eod-row\">\n            <span class=\"eod-label\">Opening</span>\n            <span class=\"eod-value\">\n                {{ \"{:,.2f}\".format(p.opening_amount or 0) }}\n            </span>\n        </div>\n\n        <div class=\"eod-row\">\n            <span class=\"eod-label\">Expected</span>\n            <span class=\"eod-value\">\n                {{ \"{:,.2f}\".format(p.expected_amount or 0) }}\n            </span>\n        </div>\n\n        <div class=\"eod-row\">\n            <span class=\"eod-label\">Counted</span>\n            <span class=\"eod-value\">\n                {{ \"{:,.2f}\".format(p.closing_amount or 0) }}\n            </span>\n        </div>\n\n        <div class=\"eod-row\">\n\n            <span class=\"eod-label\">\n                Difference\n            </span>\n\n            <span class=\"eod-value\">\n\n                {{ \"{:,.2f}\".format(diff) }}\n\n                {% if diff < 0 %}\n                    <span class=\"eod-tag short\">\n                        SHORT\n                    </span>\n                {% elif diff > 0 %}\n                    <span class=\"eod-tag over\">\n                        OVER\n                    </span>\n                {% endif %}\n\n            </span>\n\n        </div>\n\n    </div>\n\n    {% endfor %}\n\n    <!-- =========================================\n         FINAL SUMMARY\n    ========================================== -->\n\n    <div class=\"eod-section-title\">\n        Final Summary\n    </div>\n\n    <div class=\"eod-row grand\">\n        <span class=\"eod-label\">Total Expected</span>\n        <span class=\"eod-value\">\n            {{ \"{:,.2f}\".format(total_expected.v) }}\n        </span>\n    </div>\n\n    <div class=\"eod-row grand\">\n        <span class=\"eod-label\">Total Counted</span>\n        <span class=\"eod-value\">\n            {{ \"{:,.2f}\".format(total_counted.v) }}\n        </span>\n    </div>\n\n    <div class=\"eod-row grand\">\n\n        <span class=\"eod-label\">\n            Short / Over\n        </span>\n\n        <span class=\"eod-value\">\n\n            {{ \"{:,.2f}\".format(short_over) }}\n\n            {% if short_over < 0 %}\n                <span class=\"eod-tag short\">\n                    SHORT\n                </span>\n            {% elif short_over > 0 %}\n                <span class=\"eod-tag over\">\n                    OVER\n                </span>\n            {% endif %}\n\n        </span>\n\n    </div>\n\n    <!-- =========================================\n         FOOTER\n    ========================================== -->\n\n    <div class=\"eod-footer\">\n\n        Printed:\n        {{ frappe.utils.format_datetime(frappe.utils.now_datetime()) }}\n\n        <br>\n\n        by {{ frappe.session.user }}\n\n        <div class=\"eod-end\">\n            *** END ***\n        </div>\n\n    </div>\n\n</div>",
 "line_breaks": 0,
 "margin_bottom": 0.0,
 "margin_left": 0.0,
 "margin_right": 0.0,
 "margin_top": 0.0,
 "module": "POS Next",
 "name": "POS Next EOD Report",
 "print_format_builder": 0,
 "print_format_builder_beta": 0,
 "print_format_type": "Jinja",
 "raw_printing": 0,
 "show_section_headings": 0,
 "standard": "No"
}
