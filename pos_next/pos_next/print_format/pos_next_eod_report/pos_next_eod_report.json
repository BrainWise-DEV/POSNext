{
 "absolute_value": 0,
 "align_labels_right": 0,
 "custom_format": 1,
 "default_print_language": "en",
 "disabled": 0,
 "doc_type": "POS Closing Shift",
 "docstatus": 0,
 "doctype": "Print Format",
 "font_size": 11,
 "html": "<style>\n\t@page { size: 80mm auto; margin: 0; }\n\tbody {\n\t\tfont-family: 'DejaVu Sans', 'Arial', sans-serif;\n\t\twidth: 80mm;\n\t\tmax-width: 80mm;\n\t\tmargin: 0 auto;\n\t\tpadding: 8px;\n\t\tfont-size: 11px;\n\t\tline-height: 1.35;\n\t}\n\t.receipt { width: 100%; direction: ltr; color: #111827; }\n\t.text-center { text-align: center; }\n\t.brand-title { font-size: 16px; font-weight: 800; letter-spacing: 0.5px; }\n\t.brand-subtitle { font-size: 10px; margin-top: 3px; color: #4b5563; }\n\t.section { margin-top: 10px; border-top: 1px dashed #1f2937; padding-top: 8px; }\n\t.section-title { font-size: 11px; font-weight: 700; text-transform: uppercase; margin-bottom: 5px; letter-spacing: 0.2px; }\n\t.eod-row,\n\t.row { direction: ltr; display: flex; justify-content: space-between; gap: 8px; margin: 2px 0; }\n\t.label { color: #374151; }\n\t.value { text-align: right; font-weight: 600; }\n\t.muted { color: #6b7280; font-size: 10px; }\n\t.emphasis { font-size: 13px; font-weight: 800; border-top: 1px solid #111827; padding-top: 5px; margin-top: 5px; }\n\t.item-block { padding: 6px 0; border-bottom: 1px dotted #d1d5db; }\n\t.item-title { font-size: 11px; font-weight: 700; margin-bottom: 2px; }\n\t.item-meta { display: flex; justify-content: space-between; font-size: 10px; color: #4b5563; }\n\t.pay-block { margin-bottom: 7px; padding-bottom: 6px; border-bottom: 1px dotted #d1d5db; }\n\t.short-tag { color: #b91c1c; font-weight: 700; }\n\t.over-tag { color: #166534; font-weight: 700; }\n\t.summary-box { border: 1px solid #111827; border-radius: 3px; padding: 6px; margin-top: 6px; }\n\t.footer { margin-top: 12px; border-top: 1px dashed #1f2937; padding-top: 8px; text-align: center; font-size: 9px; color: #4b5563; }\n</style>\n\n{%- set items_sold = get_items_sold(doc) -%}\n{%- set taxes = doc.taxes or [] -%}\n{%- set payments = doc.payment_reconciliation or [] -%}\n{%- set tax_total = taxes | sum(attribute='amount') -%}\n{%- set total_expected = payments | sum(attribute='expected_amount') -%}\n{%- set total_counted = payments | sum(attribute='closing_amount') -%}\n{%- set summary_diff = total_counted - total_expected -%}\n{%- set profile_address = frappe.db.get_value('POS Profile', doc.pos_profile, 'address') -%}\n\n<div class=\"receipt\">\n\t<div class=\"text-center brand-title\">END-OF-DAY REPORT</div>\n\t<div class=\"text-center brand-subtitle\">{{ doc.company or 'POS Next' }}</div>\n\t{%- if profile_address -%}\n\t<div class=\"text-center brand-subtitle\">{{ profile_address }}</div>\n\t{%- endif -%}\n\n\t<div class=\"section\">\n\t\t<div class=\"section-title\">Session</div>\n\t\t<div class=\"eod-row\"><span class=\"label\">Profile</span><span class=\"value\">{{ doc.pos_profile }}</span></div>\n\t\t<div class=\"eod-row\"><span class=\"label\">Cashier</span><span class=\"value\">{{ doc.user }}</span></div>\n\t\t<div class=\"eod-row\"><span class=\"label\">Opened</span><span class=\"value\">{{ doc.period_start_date }}</span></div>\n\t\t<div class=\"eod-row\"><span class=\"label\">Closed</span><span class=\"value\">{{ doc.period_end_date }}</span></div>\n\t\t<div class=\"eod-row\"><span class=\"label\">Closing Shift</span><span class=\"value\">{{ doc.name }}</span></div>\n\t</div>\n\n\t<div class=\"section\">\n\t\t<div class=\"section-title\">Sales Totals</div>\n\t\t<div class=\"eod-row\"><span class=\"label\">Invoice Count</span><span class=\"value\">{{ (doc.pos_transactions or []) | length }}</span></div>\n\t\t<div class=\"eod-row\"><span class=\"label\">Total Qty</span><span class=\"value\">{{ '%.2f' | format(doc.total_quantity or 0) }}</span></div>\n\t\t<div class=\"eod-row\"><span class=\"label\">Net</span><span class=\"value\">{{ '%.2f' | format(doc.net_total or 0) }}</span></div>\n\t\t<div class=\"eod-row\"><span class=\"label\">Tax</span><span class=\"value\">{{ '%.2f' | format(tax_total or 0) }}</span></div>\n\t\t<div class=\"eod-row emphasis\"><span class=\"label\">Grand Total</span><span class=\"value\">{{ '%.2f' | format(doc.grand_total or 0) }}</span></div>\n\t</div>\n\n\t<div class=\"section\">\n\t\t<div class=\"section-title\">Items Sold</div>\n\t\t{%- if items_sold -%}\n\t\t\t{%- for item in items_sold -%}\n\t\t\t<div class=\"item-block\">\n\t\t\t\t<div class=\"item-title\">{{ item.item_name or item.item_code }}</div>\n\t\t\t\t<div class=\"item-meta\"><span>Qty: {{ '%.2f' | format(item.qty or 0) }}</span><span>{{ '%.2f' | format(item.amount or 0) }}</span></div>\n\t\t\t</div>\n\t\t\t{%- endfor -%}\n\t\t{%- else -%}\n\t\t\t<div class=\"muted\">No item rows found</div>\n\t\t{%- endif -%}\n\t</div>\n\n\t<div class=\"section\">\n\t\t<div class=\"section-title\">Taxes</div>\n\t\t{%- if taxes -%}\n\t\t\t{%- for tax in taxes -%}\n\t\t\t<div class=\"eod-row\"><span class=\"label\">{{ tax.account_head }} ({{ '%.2f' | format(tax.rate or 0) }}%)</span><span class=\"value\">{{ '%.2f' | format(tax.amount or 0) }}</span></div>\n\t\t\t{%- endfor -%}\n\t\t{%- else -%}\n\t\t\t<div class=\"muted\">No tax rows</div>\n\t\t{%- endif -%}\n\t</div>\n\n\t<div class=\"section\">\n\t\t<div class=\"section-title\">Payments</div>\n\t\t{%- if payments -%}\n\t\t\t{%- for payment in payments -%}\n\t\t\t<div class=\"pay-block\">\n\t\t\t\t<div class=\"eod-row\"><span class=\"label\">{{ payment.mode_of_payment }}</span><span class=\"value\"></span></div>\n\t\t\t\t<div class=\"eod-row\"><span class=\"label\">Opening</span><span class=\"value\">{{ '%.2f' | format(payment.opening_amount or 0) }}</span></div>\n\t\t\t\t<div class=\"eod-row\"><span class=\"label\">Expected</span><span class=\"value\">{{ '%.2f' | format(payment.expected_amount or 0) }}</span></div>\n\t\t\t\t<div class=\"eod-row\"><span class=\"label\">Counted</span><span class=\"value\">{{ '%.2f' | format(payment.closing_amount or 0) }}</span></div>\n\t\t\t\t<div class=\"eod-row\"><span class=\"label\">Difference</span><span class=\"value\">{{ '%.2f' | format(payment.difference or 0) }} {% if (payment.difference or 0) < 0 %}<span class='short-tag'>SHORT</span>{% elif (payment.difference or 0) > 0 %}<span class='over-tag'>OVER</span>{% endif %}</span></div>\n\t\t\t</div>\n\t\t\t{%- endfor -%}\n\t\t{%- else -%}\n\t\t\t<div class=\"muted\">No payment rows</div>\n\t\t{%- endif -%}\n\t</div>\n\n\t<div class=\"section\">\n\t\t<div class=\"section-title\">Final Summary</div>\n\t\t<div class=\"summary-box\">\n\t\t\t<div class=\"eod-row\"><span class=\"label\">Total Expected</span><span class=\"value\">{{ '%.2f' | format(total_expected or 0) }}</span></div>\n\t\t\t<div class=\"eod-row\"><span class=\"label\">Total Counted</span><span class=\"value\">{{ '%.2f' | format(total_counted or 0) }}</span></div>\n\t\t\t<div class=\"eod-row\"><span class=\"label\">Short / Over</span><span class=\"value\">{{ '%.2f' | format(summary_diff or 0) }}</span></div>\n\t\t</div>\n\t</div>\n\n\t<div class=\"footer\">\n\t\t<div>Printed at {{ frappe.utils.now_datetime() }}</div>\n\t\t<div>Printed by {{ frappe.session.user }}</div>\n\t\t<div>POS Next</div>\n\t</div>\n</div>",
 "line_breaks": 0,
 "margin_bottom": 0.0,
 "margin_left": 0.0,
 "margin_right": 0.0,
 "margin_top": 0.0,
 "module": "POS Next",
 "name": "POS Next EOD Report",
 "print_format_builder": 0,
 "print_format_builder_beta": 0,
 "print_format_type": "Jinja",
 "raw_printing": 0,
 "show_section_headings": 0,
 "standard": "No"
}
